# Copy to ios/fastlane/.env for local development (never commit .env).
# GitHub Actions uses repository secrets instead.

FASTLANE_USER=your-apple-id@example.com
# FASTLANE_PASSWORD=          # local only; prefer API key on CI
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=

APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# APP_STORE_CONNECT_API_KEY_CONTENT="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Local Apple ID 2FA only — do not set on CI
# SPACESHIP_2FA_SMS_DEFAULT_PHONE_NUMBER=+1234567890
