# Get the project root directory (two levels up from fastlane directory)
# Fastfile is in ios/fastlane/, so ../.. gets us to project root
FASTLANE_DIR = File.dirname(__FILE__)
IOS_DIR = File.expand_path("..", FASTLANE_DIR)
PROJECT_ROOT = File.expand_path("..", IOS_DIR)

require "shellwords"

# Keys passed to Flutter via --dart-define (must match lib/core/environment.dart).
FLUTTER_DART_DEFINE_KEYS = %w[
  SUPABASE_URL
  SUPABASE_PUBLISHABLE_KEY
  SUPABASE_ANON_KEY
  GOOGLE_MAPS_API_KEY
].freeze

# Required on CI — injected from GitHub repository secrets only (never env files).
CI_REQUIRED_DART_DEFINE_KEYS = %w[
  SUPABASE_URL
  SUPABASE_PUBLISHABLE_KEY
  GOOGLE_MAPS_API_KEY
].freeze

def ci_build?
  ENV["CI"] == "true"
end

# PATH that prefers system Ruby 2.6 (avoids Homebrew Ruby 3.4 when running bundle/pod from fastlane)
def path_for_system_ruby
  "/usr/bin:/usr/local/bin:#{ENV['PATH']}"
end

# User gem dir so bundle finds gems (e.g. concurrent-ruby 1.3.4) without sudo
def gem_home_for_bundle
  home = ENV["HOME"] || ENV["USERPROFILE"] || Dir.home
  "#{home}/.gem/ruby/#{RbConfig::CONFIG['ruby_version']}"
end

# GEM_PATH: user dir first (concurrent-ruby 1.3.4), then system (ffi native for current arch)
def gem_path_for_bundle
  "#{gem_home_for_bundle}:/Library/Ruby/Gems/2.6.0"
end

# Helper function to find pod command
def find_pod_command
  possible_paths = [
    "/Library/Ruby/Gems/2.6.0/bin/pod",
    "/usr/local/bin/pod",
    "/opt/homebrew/bin/pod"
  ]
  possible_paths.each do |path|
    return path if File.exist?(path)
  end
  pod_path = `which pod 2>/dev/null`.strip
  return pod_path unless pod_path.empty?
  return "pod"
end

# Run pod install. Prefer install_gems_and_pods.sh (native arm64 Ruby, avoids ffi_c mismatch); then bundle exec; then system pod.
# Returns true if we have a pod wrapper or script succeeded, false if we used system pod.
def run_pod_install
  install_script = File.join(IOS_DIR, "install_gems_and_pods.sh")
  if File.executable?(install_script)
    UI.message("Running pod install via install_gems_and_pods.sh (native Ruby, avoids ffi arch mismatch)...")
    begin
      home = ENV["HOME"] || ENV["USERPROFILE"] || Dir.home
      sh("cd #{PROJECT_ROOT} && env HOME=\"#{home}\" LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 #{install_script}", log: true)
      UI.success("✅ pod install completed (via install_gems_and_pods.sh)")
      return true
    rescue => script_ex
      UI.important("⚠️  install script failed: #{script_ex.message}")
    end
  end

  UI.message("Running pod install (trying bundle exec)...")
  ruby_bin = RbConfig.ruby
  begin
    gem_home = gem_home_for_bundle
    gem_path = gem_path_for_bundle
    sh("cd #{IOS_DIR} && env PATH=\"#{path_for_system_ruby}\" GEM_HOME=\"#{gem_home}\" GEM_PATH=\"#{gem_path}\" #{ruby_bin} -S bundle exec pod install --repo-update", log: true)
    UI.success("✅ pod install completed (bundle exec)")
    return true
  rescue => ex
    UI.important("⚠️  bundle exec pod failed: #{ex.message}")
    UI.important("Trying system pod...")
    pod_cmd = find_pod_command
    begin
      system_path = "/usr/bin:#{ENV['PATH']}"
      sh("cd #{IOS_DIR} && env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u BUNDLE_PATH PATH=\"#{system_path}\" #{pod_cmd} install --repo-update", log: true)
      UI.success("✅ pod install completed (system pod)")
      return false
    rescue => sys_ex
      UI.important("⚠️  system pod also failed: #{sys_ex.message}")
      pods_lock = File.join(IOS_DIR, "Pods", "Manifest.lock")
      if File.exist?(pods_lock)
        UI.important("Continuing (Pods/Manifest.lock exists). If build fails, run: ./ios/install_gems_and_pods.sh")
        return true
      end
      UI.user_error!(
        "Pod install failed. Run from project root: ./ios/install_gems_and_pods.sh then retry."
      )
    end
  end
end

# Ensure a pod wrapper exists so Flutter's internal pod install uses bundle exec (avoids "CocoaPods broken" when Ruby differs)
def ensure_pod_wrapper_for_flutter
  wrapper_dir = File.join(IOS_DIR, ".pod_wrapper")
  FileUtils.mkdir_p(wrapper_dir)
  wrapper_script = File.join(wrapper_dir, "pod")
  gem_home = gem_home_for_bundle
  gem_path = gem_path_for_bundle
  script_content = <<~BASH
    #!/bin/bash
    export PATH="/usr/bin:/usr/local/bin:$PATH"
    export GEM_HOME="#{gem_home}"
    export GEM_PATH="#{gem_path}"
    cd #{IOS_DIR.inspect} && bundle exec pod "$@"
  BASH
  need_write = !File.exist?(wrapper_script) || File.read(wrapper_script) != script_content
  if need_write
    File.write(wrapper_script, script_content)
    File.chmod(0755, wrapper_script)
    UI.message("Created pod wrapper at #{wrapper_script}")
  end
  wrapper_dir
end

# Build App Store Connect API key params from env vars (for CI).
# Returns nil if env vars are not set (local dev falls back to Apple ID).
def app_store_connect_api_key_params
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
  key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
  return nil if key_id.nil? || issuer_id.nil? || key_content.nil?
  return nil if key_id.empty? || issuer_id.empty? || key_content.empty?
  { key_id: key_id, issuer_id: issuer_id, key_content: key_content }
end

# CI must never use Apple ID / SMS 2FA (non-interactive). Strip creds fastlane may load from .env.
def scrub_apple_id_auth_for_ci!
  return unless ENV["CI"]

  %w[
    SPACESHIP_2FA_SMS_DEFAULT_PHONE_NUMBER
    FASTLANE_SESSION
    FASTLANE_PASSWORD
    FASTLANE_USER
    FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD
  ].each { |key| ENV.delete(key) }
end

scrub_apple_id_auth_for_ci!

def parse_env_file(path, vars)
  return unless File.exist?(path)

  File.foreach(path) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    next unless line =~ /\A([A-Za-z_][A-Za-z0-9_]*)=(.*)\z/

    key = Regexp.last_match(1)
    val = Regexp.last_match(2).gsub(/\A["']|["']\z/, "")
    vars[key] = val unless val.empty?
  end
end

def load_env_file_vars
  vars = {}
  if ci_build?
    CI_REQUIRED_DART_DEFINE_KEYS.each do |key|
      val = ENV[key]
      vars[key] = val if val && !val.empty?
    end
    missing = CI_REQUIRED_DART_DEFINE_KEYS.reject { |key| vars[key] && !vars[key].empty? }
    unless missing.empty?
      UI.user_error!(
        "TestFlight CI requires GitHub secrets (not env files): #{missing.join(', ')}"
      )
    end
  else
    parse_env_file(File.join(PROJECT_ROOT, "env", ".env.local"), vars)
    FLUTTER_DART_DEFINE_KEYS.each do |key|
      env_val = ENV[key]
      vars[key] = env_val if env_val && !env_val.empty?
    end
  end
  vars
end

def flutter_dart_define_args
  vars = load_env_file_vars

  args = ["--dart-define=ENV=prod"]
  FLUTTER_DART_DEFINE_KEYS.each do |key|
    val = vars[key]
    next if val.nil? || val.empty?
    next if val.include?("YOUR_PROJECT_REF") || val.end_with?("...")

    args << "--dart-define=#{key}=#{val}"
  end
  Shellwords.shelljoin(args)
end

def build_app_store_connect_api_key
  params = app_store_connect_api_key_params
  return nil unless params

  key_path = File.join(Dir.home, ".appstoreconnect", "api_key.p8")
  if File.exist?(key_path)
    app_store_connect_api_key(
      key_id: params[:key_id],
      issuer_id: params[:issuer_id],
      key_filepath: key_path
    )
  else
    app_store_connect_api_key(
      key_id: params[:key_id],
      issuer_id: params[:issuer_id],
      key_content: params[:key_content],
      is_key_content_base64: false
    )
  end
end

def testflight_upload_options(ipa_path, changelog: nil)
  scrub_apple_id_auth_for_ci!

  options = {
    ipa: ipa_path,
    app_identifier: "com.triftly",
    skip_waiting_for_build_processing: ENV["CI"] ? true : false,
    skip_submission: true,
    distribute_external: false,
    notify_external_testers: false
  }
  options[:changelog] = changelog if changelog && !changelog.to_s.strip.empty?

  api_key = build_app_store_connect_api_key
  if api_key
    options[:api_key] = api_key
    UI.message("🔑 Using App Store Connect API key for TestFlight upload (no Apple ID / 2FA)")
  elsif ENV["CI"]
    UI.user_error!(
      "APP_STORE_CONNECT_API_KEY_ID, APP_STORE_CONNECT_ISSUER_ID, and " \
      "APP_STORE_CONNECT_API_KEY_CONTENT must be set in GitHub Actions secrets."
    )
  end

  options
end

def connect_api_for_spaceship
  params = app_store_connect_api_key_params
  return nil unless params

  key_path = File.join(Dir.home, ".appstoreconnect", "api_key.p8")
  token = if File.exist?(key_path)
            Spaceship::ConnectAPI::Token.create(
              key_id: params[:key_id],
              issuer_id: params[:issuer_id],
              filepath: key_path
            )
          else
            Spaceship::ConnectAPI::Token.create(
              key_id: params[:key_id],
              issuer_id: params[:issuer_id],
              key: params[:key_content]
            )
          end

  Spaceship::ConnectAPI.token = token
  token
end

def associated_domains_entitlements_enabled?
  entitlements_path = File.join(IOS_DIR, "Runner/Runner.entitlements")
  return false unless File.exist?(entitlements_path)

  File.read(entitlements_path).include?("com.apple.developer.associated-domains")
end

def associated_domains_capability_enabled?(app_identifier: "com.triftly")
  connect_api_for_spaceship unless Spaceship::ConnectAPI.token
  return false unless Spaceship::ConnectAPI.token

  bundle_id = Spaceship::ConnectAPI::BundleId.find(app_identifier)
  return false unless bundle_id

  capability_type = Spaceship::ConnectAPI::BundleIdCapability::Type::ASSOCIATED_DOMAINS
  Spaceship::ConnectAPI::BundleIdCapability.all(bundle_id_id: bundle_id.id)
    .any? { |cap| cap.capability_type == capability_type }
rescue StandardError => ex
  UI.important("⚠️  Could not verify Associated Domains capability: #{ex.message}")
  false
end

def strip_code_sign_entitlements_for_ci!
  pbxproj = File.join(IOS_DIR, "Runner.xcodeproj/project.pbxproj")
  content = File.read(pbxproj)
  new_content = content.gsub(/^\t\t\t\tCODE_SIGN_ENTITLEMENTS = Runner\/Runner.entitlements;\n/m, "")
  return if new_content == content

  File.write(pbxproj, new_content)
  UI.message("Removed CODE_SIGN_ENTITLEMENTS for CI build (Associated Domains not enabled on App ID yet)")
end

# Returns true when the App Store profile should include Associated Domains entitlements.
def prepare_associated_domains_signing!(app_identifier: "com.triftly")
  return true unless associated_domains_entitlements_enabled?

  if associated_domains_capability_enabled?(app_identifier: app_identifier)
    UI.message("✅ Associated Domains enabled on #{app_identifier}")
    return true
  end

  if ENV["CI"]
    UI.important("⚠️  Associated Domains not enabled on #{app_identifier} yet")
    UI.important("    1. Apple Developer → Identifiers → com.triftly → Associated Domains")
    UI.important("    2. Re-run Deploy — TestFlight will include universal link entitlements")
    UI.important("    Building without entitlements for now so CI can ship.")
    strip_code_sign_entitlements_for_ci!
    return false
  end

  UI.user_error!(
    "Enable Associated Domains for #{app_identifier} in Apple Developer → Identifiers, " \
    "then re-run setup_appstore_signing."
  )
end

def prune_certificates_of_type(type, keep:, revoked_ids:)
  certs = Spaceship::ConnectAPI::Certificate.all(filter: { certificateType: type })
  certs = certs.reject { |cert| revoked_ids.include?(cert.id) }
  UI.message("Found #{certs.length} #{type} certificate(s)")
  return if certs.length <= keep

  sorted = certs.sort_by { |cert| cert.expiration_date.to_s }
  revoke_list = sorted[0...(sorted.length - keep)]
  revoke_list.each do |cert|
    UI.message("Revoking #{type} certificate #{cert.display_name} (#{cert.id})")
    cert.delete!
    revoked_ids << cert.id
  end
end

def persist_ci_signing_env!
  return unless ENV["CI"] && ENV["GITHUB_ENV"] && ENV["SIGH_NAME"]

  File.open(ENV["GITHUB_ENV"], "a") do |file|
    file.puts "SIGH_NAME=#{ENV['SIGH_NAME']}"
    file.puts "SIGH_NAME_TRIFTLY_SHARE=#{ENV['SIGH_NAME_TRIFTLY_SHARE']}" if ENV["SIGH_NAME_TRIFTLY_SHARE"]
  end
end

TRIFTLY_SHARE_BUNDLE_ID = "com.triftly.TriftlyShare"

def fetch_appstore_profile!(app_identifier:, force: false)
  api_key_params = app_store_connect_api_key_params
  profile_options = {
    app_identifier: app_identifier,
    team_id: "3G34999H3A",
    force: force
  }
  if api_key_params
    profile_options[:api_key] = app_store_connect_api_key(**api_key_params)
    profile_options[:cert_id] = distribution_cert_id_for_ci if ENV["CI"]
  else
    profile_options[:username] = ENV["FASTLANE_USER"] || "wayneyu.dev@gmail.com"
  end
  get_provisioning_profile(**profile_options)
  ENV["SIGH_NAME"]
end

def ci_signing_keychain_path
  File.expand_path("~/Library/Keychains/triftly-ci.keychain-db")
end

CI_SIGNING_KEYCHAIN_PASSWORD = "triftly-ci-keychain"

def setup_ci_signing_keychain!
  keychain = ci_signing_keychain_path
  login_keychain = File.expand_path("~/Library/Keychains/login.keychain-db")

  sh("security delete-keychain '#{keychain}' 2>/dev/null || true", log: false)
  sh("security create-keychain -p '#{CI_SIGNING_KEYCHAIN_PASSWORD}' '#{keychain}'", log: false)
  sh("security unlock-keychain -p '#{CI_SIGNING_KEYCHAIN_PASSWORD}' '#{keychain}'", log: false)
  sh("security set-keychain-settings -lut 21600 '#{keychain}'", log: false)
  sh("security list-keychains -d user -s '#{keychain}' '#{login_keychain}'", log: false)
  keychain
end

def distribution_identity_installed?
  keychain = ENV["CI"] ? ci_signing_keychain_path : File.expand_path("~/Library/Keychains/login.keychain-db")
  output = `security find-identity -v -p codesigning '#{keychain}' 2>/dev/null`
  output.include?("Apple Distribution") && output.include?("3G34999H3A")
end

def import_distribution_certificate_for_ci!
  return false unless ENV["CI"]

  cert_b64 = ENV["IOS_DISTRIBUTION_CERT_BASE64"]
  return false if cert_b64.nil? || cert_b64.strip.empty?

  require "base64"
  p12_path = File.join(IOS_DIR, "distribution.ci.p12")
  File.binwrite(p12_path, Base64.decode64(cert_b64))

  keychain = setup_ci_signing_keychain!

  import_certificate(
    certificate_path: p12_path,
    certificate_password: ENV["IOS_DISTRIBUTION_CERT_PASSWORD"] || "",
    keychain_path: keychain,
    keychain_password: CI_SIGNING_KEYCHAIN_PASSWORD
  )

  sh(
    "security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '#{CI_SIGNING_KEYCHAIN_PASSWORD}' '#{keychain}'",
    log: false
  )

  File.delete(p12_path) if File.exist?(p12_path)
  UI.success("✅ Imported distribution certificate into CI keychain")
  true
ensure
  File.delete(p12_path) if defined?(p12_path) && p12_path && File.exist?(p12_path)
end

def distribution_cert_id_for_ci
  connect_api_for_spaceship
  certs = Spaceship::ConnectAPI::Certificate.all(filter: { certificateType: "DISTRIBUTION" })
  certs = certs.select(&:valid?)
  UI.user_error!("No valid DISTRIBUTION certificate found in App Store Connect") if certs.empty?

  cert = certs.max_by { |c| c.expiration_date.to_s }
  UI.message("Using portal distribution certificate #{cert.id} (#{cert.display_name})")
  cert.id
end

def write_ci_export_options_plist!
  profile_name = ENV["SIGH_NAME"]
  share_profile_name = ENV["SIGH_NAME_TRIFTLY_SHARE"]
  UI.user_error!("SIGH_NAME is required to export the App Store IPA on CI.") unless profile_name
  UI.user_error!("SIGH_NAME_TRIFTLY_SHARE is required to export the App Store IPA on CI.") unless share_profile_name

  plist_path = File.join(IOS_DIR, "ExportOptions.ci.plist")
  plist_content = <<~PLIST
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>method</key>
      <string>app-store</string>
      <key>signingStyle</key>
      <string>manual</string>
      <key>teamID</key>
      <string>3G34999H3A</string>
      <key>provisioningProfiles</key>
      <dict>
        <key>com.triftly</key>
        <string>#{profile_name}</string>
        <key>#{TRIFTLY_SHARE_BUNDLE_ID}</key>
        <string>#{share_profile_name}</string>
      </dict>
    </dict>
    </plist>
  PLIST

  File.write(plist_path, plist_content)
  plist_path
end

def ensure_runner_ipa_path!
  runner_ipa = File.join(PROJECT_ROOT, "build/ios/ipa/Runner.ipa")
  return runner_ipa if File.exist?(runner_ipa)

  ipa_files = Dir.glob(File.join(PROJECT_ROOT, "build/ios/ipa/*.ipa"))
  UI.user_error!("No IPA found under build/ios/ipa after export.") if ipa_files.empty?

  FileUtils.cp(ipa_files.first, runner_ipa)
  runner_ipa
end

default_platform(:ios)

def latest_app_store_build_number(version_name: nil)
  connect_api_for_spaceship unless Spaceship::ConnectAPI.token

  options = { app_identifier: "com.triftly" }
  options[:version] = version_name if version_name
  api_key = build_app_store_connect_api_key
  options[:api_key] = api_key if api_key

  latest_testflight_build_number(**options).to_i
rescue => ex
  UI.important("⚠️  Could not fetch latest TestFlight build: #{ex.message}")
  0
end

def error_full_text(error)
  parts = [error.message, error.to_s]
  parts << error.inspect if error.respond_to?(:inspect)
  parts << (error.backtrace || []).join("\n")
  parts.compact.join("\n")
end

def duplicate_build_upload_error?(error)
  text = error_full_text(error)
  text.include?("already been used") ||
    text.include?("ENTITY_ERROR.ATTRIBUTE.INVALID.DUPLICATE") ||
    text.include?("INVALID.DUPLICATE") ||
    text.include?("bundle version must be higher") ||
    text.include?("previously uploaded version")
end

def parse_duplicate_build_number(error)
  text = error_full_text(error)
  if (match = text.match(/previousBundleVersion\s*:\s*(\d+)/i))
    return match[1].to_i
  end
  if (match = text.match(/previously uploaded version:\s*['"]?(\d+)/i))
    return match[1].to_i
  end
  nil
end

def write_build_number_to_pubspec(version_name, new_build)
  pubspec_path = File.join(PROJECT_ROOT, "pubspec.yaml")
  content = File.read(pubspec_path)
  new_content = content.gsub(/^version:\s*\d+\.\d+\.\d+\+\d+/, "version: #{version_name}+#{new_build}")
  File.write(pubspec_path, new_content)
end

# Helper function to increment build number in pubspec.yaml
def increment_build_number_in_pubspec(minimum_build: nil)
  pubspec_path = File.join(PROJECT_ROOT, "pubspec.yaml")
  
  unless File.exist?(pubspec_path)
    UI.user_error!("❌ pubspec.yaml not found at #{pubspec_path}")
  end
  
  content = File.read(pubspec_path)
  version_match = content.match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
  
  unless version_match
    UI.user_error!("❌ Could not parse version from pubspec.yaml. Expected format: version: 1.0.0+18")
  end
  
  version_name = version_match[1]
  current_build = version_match[2].to_i
  asc_latest = latest_app_store_build_number(version_name: version_name)
  asc_latest_any = latest_app_store_build_number
  remote_high = [asc_latest, asc_latest_any, minimum_build.to_i].max
  new_build = [current_build, remote_high].max + 1

  if remote_high >= current_build
    UI.message(
      "📦 App Store Connect latest build is #{remote_high}; " \
      "setting pubspec build to #{new_build} (was #{current_build})"
    )
  else
    UI.message("📦 Incrementing build number: #{current_build} → #{new_build}")
  end

  write_build_number_to_pubspec(version_name, new_build)
  UI.success("✅ Build number updated to #{new_build}")
  [version_name, new_build]
end

BUILD_NUMBER_COMMIT_PATTERN = "Auto-increment build number".freeze

def build_number_commit?(message)
  message.include?(BUILD_NUMBER_COMMIT_PATTERN) || message.start_with?("chore: Auto-increment")
end

def pubspec_version_label
  pubspec_path = File.join(PROJECT_ROOT, "pubspec.yaml")
  return nil unless File.exist?(pubspec_path)

  match = File.read(pubspec_path).match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
  return nil unless match

  "#{match[1]} (#{match[2]})"
end

# Commits since the last CI build-number bump — used for TestFlight "What to Test".
def generate_release_notes
  build_time = Time.now.strftime("%Y-%m-%d %H:%M")
  version_label = pubspec_version_label

  unless system("cd #{PROJECT_ROOT} && git rev-parse --git-dir > /dev/null 2>&1")
    UI.important("⚠️  Not a git repository, using default release notes")
    return "Manual build\n#{version_label}\n#{build_time}"
  end

  last_build_sha = `cd #{PROJECT_ROOT} && git log -1 --pretty=format:%H --grep='#{BUILD_NUMBER_COMMIT_PATTERN}'`.strip
  git_range = last_build_sha.empty? ? "-15" : "#{last_build_sha}..HEAD"

  commit_output = `cd #{PROJECT_ROOT} && git log #{git_range} --pretty=format:"%s" --no-merges`.strip
  valid_commits = commit_output.split("\n").map(&:strip).reject do |message|
    message.empty? || build_number_commit?(message)
  end

  valid_commits = ["Manual build"] if valid_commits.empty?

  lines = ["What's in this build", ""]
  valid_commits.each { |message| lines << "• #{message[0..200]}" }
  lines << ""
  lines << "Version #{version_label}" if version_label
  lines << "Built #{build_time}"

  prefix = ENV["TESTFLIGHT_CHANGELOG_PREFIX"].to_s.strip
  lines.unshift(prefix, "") unless prefix.empty?

  release_notes = lines.join("\n")[0..3900]

  UI.message("📝 TestFlight What to Test (#{valid_commits.length} commit(s) since last build):")
  UI.message(release_notes)

  release_notes
rescue => ex
  UI.important("⚠️  Failed to generate release notes from git: #{ex.message}")
  fallback = ["Manual build", ("Version #{version_label}" if version_label), "Built #{build_time}"].compact.join("\n")
  fallback
end

# Helper function to commit and push build number change
def commit_and_push_build_number(version_name, new_build_number)
  UI.message("📝 Committing build number change...")
  
  begin
    # In CI, set git identity so commit works
    if ENV['CI']
      sh("cd #{PROJECT_ROOT} && git config user.email 'ci-bot@triftly.app'")
      sh("cd #{PROJECT_ROOT} && git config user.name 'Triftly CI'")
    end

    # Check if we're in a git repository
    unless system("cd #{PROJECT_ROOT} && git rev-parse --git-dir > /dev/null 2>&1")
      UI.important("⚠️  Not a git repository, skipping commit")
      return
    end
    
    # Check if there are uncommitted changes to pubspec.yaml
    git_status = `cd #{PROJECT_ROOT} && git status --porcelain pubspec.yaml`.strip
    if git_status.empty?
      UI.important("ℹ️  No changes to pubspec.yaml, skipping commit")
      return
    end
    
    # Stage the pubspec.yaml file
    sh("cd #{PROJECT_ROOT} && git add pubspec.yaml")
    
    # Commit with a descriptive message (use actual version from pubspec, e.g. 1.0.1+4)
    # Use multiple -m flags for multi-line commit message
    sh("cd #{PROJECT_ROOT} && git commit -m 'chore: Auto-increment build number to #{new_build_number} [skip ci]' -m 'Build number automatically incremented by Fastfile' -m 'Updated to #{version_name}+#{new_build_number}'")
    
    UI.success("✅ Build number change committed")
    
    # Push to remote
    UI.message("🚀 Pushing to remote repository...")
    sh("cd #{PROJECT_ROOT} && git push")
    
    UI.success("✅ Build number change pushed to remote")
  rescue => ex
    UI.important("⚠️  Failed to commit/push build number: #{ex.message}")
    UI.important("   You may need to commit and push manually")
  end
end

platform :ios do
  desc "Build iOS app for development (Debug)"
  lane :build_debug do
    # Get dependencies
    sh("cd #{PROJECT_ROOT} && flutter pub get")
    
    # Run pod install explicitly to ensure CocoaPods dependencies are up to date
    run_pod_install
    
    # Build iOS app in debug mode
    # Using clean environment to avoid Bundler conflicts with CocoaPods
    sh("cd #{PROJECT_ROOT} && env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u BUNDLE_PATH flutter build ios --debug --no-codesign")
    
    UI.success("✅ iOS Debug build completed!")
  end

  desc "Build iOS app for release"
  lane :build_release do
    # Get dependencies
    sh("cd #{PROJECT_ROOT} && flutter pub get")
    
    # Run pod install explicitly to ensure CocoaPods dependencies are up to date
    run_pod_install
    
    # Build iOS app in release mode
    # Using clean environment to avoid Bundler conflicts with CocoaPods
    sh("cd #{PROJECT_ROOT} && env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u BUNDLE_PATH flutter build ios --release --no-codesign")
    
    UI.success("✅ iOS Release build completed!")
  end

  desc "Build iOS app and create IPA (requires code signing)"
  desc "Options: export_method - 'development', 'ad-hoc', 'app-store', or 'enterprise' (default: 'development')"
  lane :build_ipa do |options|
    export_method = options[:export_method] || "development"
    
    # Get dependencies
    sh("cd #{PROJECT_ROOT} && flutter pub get")
    
    # Ensure Ruby gems are installed (use PATH + GEM_HOME for system Ruby / user gems)
    UI.message("Ensuring bundle is up to date (ios/Gemfile)...")
    begin
      gem_home = gem_home_for_bundle
      sh("cd #{IOS_DIR} && env PATH=\"#{path_for_system_ruby}\" GEM_HOME=\"#{gem_home}\" GEM_PATH=\"#{gem_home}\" bundle install", log: true)
    rescue => ex
      UI.important("⚠️  bundle install had an issue: #{ex.message}")
    end
    
    # Run pod install (bundle exec or system pod)
    bundle_pod_ok = run_pod_install

    if ENV["CI"] && export_method == "app-store"
      UI.message("🔧 CI: applying App Store signing to Xcode project...")
      if ENV["SIGH_NAME"] && ENV["SIGH_NAME_TRIFTLY_SHARE"]
        update_code_signing_settings(
          use_automatic_signing: false,
          path: "#{IOS_DIR}/Runner.xcodeproj",
          team_id: "3G34999H3A",
          bundle_identifier: "com.triftly",
          profile_name: ENV["SIGH_NAME"],
          code_sign_identity: "Apple Distribution",
          targets: ["Runner"]
        )
        update_code_signing_settings(
          use_automatic_signing: false,
          path: "#{IOS_DIR}/Runner.xcodeproj",
          team_id: "3G34999H3A",
          bundle_identifier: TRIFTLY_SHARE_BUNDLE_ID,
          profile_name: ENV["SIGH_NAME_TRIFTLY_SHARE"],
          code_sign_identity: "Apple Distribution",
          targets: ["TriftlyShare"]
        )
      else
        UI.user_error!(
          "SIGH_NAME and SIGH_NAME_TRIFTLY_SHARE must be set. Run the Prepare App Store signing workflow step first."
        )
      end

      export_plist = write_ci_export_options_plist!
      dart_defines = flutter_dart_define_args
      UI.message("📦 Building IPA via flutter build ipa...")
      sh("cd #{PROJECT_ROOT} && flutter build ipa --release #{dart_defines} --export-options-plist=#{export_plist}")
      ensure_runner_ipa_path!
    else
      # Step 1: Build Flutter artifacts (no codesign — gym handles signing)
      dart_defines = flutter_dart_define_args
      UI.message("🔧 Step 1/2: Building Flutter artifacts...")
      sh("cd #{PROJECT_ROOT} && flutter build ios --release --no-codesign #{dart_defines}")

      # Step 2: Archive + export IPA using gym with xcodebuild auth flags
      UI.message("📦 Step 2/2: Archiving and exporting IPA via gym...")

      xcargs = "-allowProvisioningUpdates COMPILER_INDEX_STORE_ENABLE=NO"
      api_key_params = app_store_connect_api_key_params
      if api_key_params
        key_path = File.join(Dir.home, ".appstoreconnect", "api_key.p8")
        if File.exist?(key_path)
          xcargs += " -authenticationKeyID #{api_key_params[:key_id]}"
          xcargs += " -authenticationKeyIssuerID #{api_key_params[:issuer_id]}"
          xcargs += " -authenticationKeyPath #{key_path}"
          UI.message("🔑 Using App Store Connect API key for xcodebuild auth")
        end
      end

      build_app(
        workspace: "#{IOS_DIR}/Runner.xcworkspace",
        scheme: "Runner",
        configuration: "Release",
        export_method: export_method,
        output_directory: "#{PROJECT_ROOT}/build/ios/ipa",
        export_options: {
          method: export_method,
          signingStyle: "manual",
          teamID: "3G34999H3A",
          provisioningProfiles: {
            "com.triftly" => ENV["SIGH_NAME"],
            TRIFTLY_SHARE_BUNDLE_ID => ENV["SIGH_NAME_TRIFTLY_SHARE"]
          }.compact
        },
        export_team_id: "3G34999H3A",
        xcargs: xcargs,
        clean: false,
        include_bitcode: false,
      )
    end

    UI.success("✅ IPA created successfully!")
    UI.message("📦 IPA location: #{PROJECT_ROOT}/build/ios/ipa/")
  end

  desc "Build IPA and upload to TestFlight"
  desc "Options: skip_build - set to true to skip building and use existing IPA (default: false)"
  lane :upload_testflight do |options|
    skip_build = options[:skip_build] || false
    version_name = nil
    new_build_number = nil

    unless skip_build
      # Automatically increment build number before building
      UI.important("🔢 Auto-incrementing build number...")
      version_name, new_build_number = increment_build_number_in_pubspec
      UI.important("")
      
      UI.important("📦 Building IPA for App Store...")
      UI.important("⚠️  Note: App Store builds require Distribution certificate and App Store provisioning profile")
      UI.important("")
      
      build_success = false
      retry_count = 0
      max_retries = 1
      
      begin
        # Build IPA with app-store export method for TestFlight
        # Pass the environment to build_ipa
        build_ipa(export_method: "app-store")
        build_success = true
      rescue => ex
        error_msg = ex.message
        
        # Check if it's a certificate/provisioning profile error
        is_signing_error = error_msg.include?("provisioning profile") || 
                          error_msg.include?("certificate") || 
                          error_msg.include?("signing") ||
                          error_msg.include?("CodeSign") ||
                          error_msg.include?("packaging")
        
        if is_signing_error && retry_count < max_retries
          retry_count += 1
          UI.important("")
          UI.important("🔧 Detected code signing issue. Retrying with Xcode automatic signing...")
          UI.important("")
          
          begin
            # Retry the build — xcodebuild with automatic signing should handle it
            build_ipa(export_method: "app-store")
            build_success = true
          rescue => setup_ex
            UI.error("")
            UI.error("❌ Build failed again: #{setup_ex.message}")
            UI.error("")
            raise
          end
        else
          # Not a signing error or already retried
          UI.error("❌ Failed to build IPA for App Store")
          UI.error("   Error: #{error_msg}")
          UI.error("")
          
          if is_signing_error
            UI.error("   This appears to be a code signing issue.")
            UI.error("   Try running: bundle exec fastlane ios setup_appstore_signing")
          end
          UI.error("")
          raise
        end
      end
      
      unless build_success
        UI.user_error!("Failed to build IPA for App Store after setup attempts")
      end
    end
    
    # Find the IPA file
    ipa_path = "#{PROJECT_ROOT}/build/ios/ipa/Runner.ipa"
    
    unless File.exist?(ipa_path)
      UI.user_error!("❌ IPA file not found at #{ipa_path}.\n" +
                    "   Please build the IPA first or run without skip_build option.\n" +
                    "   For development/testing, use: bundle exec fastlane ios build_ipa")
    end
    
    UI.message("🚀 Uploading to TestFlight...")
    ENV["PILOT_SKIP_WAITING_FOR_BUILD_PROCESSING"] = "0"
    
    # Log exactly what we're uploading so you can match in App Store Connect
    pubspec_path = File.join(PROJECT_ROOT, "pubspec.yaml")
    uploaded_version = nil
    uploaded_build = nil
    if File.exist?(pubspec_path)
      version_match = File.read(pubspec_path).match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
      if version_match
        uploaded_version = version_match[1]
        uploaded_build = version_match[2]
        UI.message("📋 Uploading: version #{uploaded_version}, build #{uploaded_build} (from pubspec → IPA)")
      end
    end
    UI.message("📋 IPA path: #{ipa_path}")
    UI.message("📋 App identifier: com.triftly (itc_team_id: 128328295)")
    if File.exist?(ipa_path)
      mtime = File.mtime(ipa_path)
      UI.message("📋 IPA last modified: #{mtime.localtime.strftime('%Y-%m-%d %H:%M:%S')} (should be from this run)")
    end
    UI.message("")
    UI.important("ℹ️  'Successfully uploaded' = Apple's servers received the file. Build may take 5–30 min to appear (or fail processing → check email).")
    UI.message("📋 If build never appears: App Store Connect → Triftly → TestFlight → 构建版本上传 → 查看更多; or check email for processing errors.")
    UI.message("📋 Verbose logs: bundle exec fastlane ios upload_testflight --verbose")
    UI.message("")
    
    release_notes = generate_release_notes
    UI.message("📝 Uploading TestFlight What to Test notes with this build.")
    UI.message("")

    upload_attempts = 0
    max_upload_attempts = 3

    begin
      upload_attempts += 1
      upload_to_testflight(**testflight_upload_options(ipa_path, changelog: release_notes))

      UI.success("✅ Successfully uploaded to App Store Connect!")
      if uploaded_build
        UI.message("📱 Look for build #{uploaded_build} (version #{uploaded_version}) in TestFlight → 构建版本上传. Processing usually 5–30 min; if missing after 24h, contact Apple or re-upload with next build number.")
      else
        UI.message("📱 Build will appear in App Store Connect in 5–30 min. If it does not, check email for processing errors or re-upload.")
      end

      if !skip_build && version_name && new_build_number
        commit_and_push_build_number(version_name, new_build_number)
      end
    rescue => ex
      should_retry_duplicate = duplicate_build_upload_error?(ex)

      unless should_retry_duplicate || skip_build
        asc_latest = latest_app_store_build_number(version_name: uploaded_version)
        if uploaded_build && uploaded_build.to_i > asc_latest
          should_retry_duplicate = true
          UI.important(
            "⚠️  Upload failed and App Store Connect latest (#{asc_latest}) " \
            "is behind our build (#{uploaded_build}); treating as duplicate/race."
          )
        end
      end

      if should_retry_duplicate && !skip_build && upload_attempts < max_upload_attempts
        duplicate_floor = [
          parse_duplicate_build_number(ex),
          uploaded_build&.to_i
        ].compact.max

        UI.important("")
        UI.important(
          "🔢 Build number already on App Store Connect" \
          "#{duplicate_floor ? " (#{duplicate_floor})" : ""}. " \
          "Bumping, rebuilding, and retrying upload (attempt #{upload_attempts + 1}/#{max_upload_attempts})..."
        )
        UI.important("")

        version_name, new_build_number = increment_build_number_in_pubspec(minimum_build: duplicate_floor)
        build_ipa(export_method: "app-store")
        ipa_path = ensure_runner_ipa_path!

        version_match = File.read(pubspec_path).match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
        if version_match
          uploaded_version = version_match[1]
          uploaded_build = version_match[2]
          UI.message("📋 Retrying upload: version #{uploaded_version}, build #{uploaded_build}")
        end

        release_notes = generate_release_notes
        retry
      end

      error_msg = ex.message

      if error_msg.include?("Couldn't find app") || error_msg.include?("not found on the account")
        UI.important("")
        UI.important("🔧 App not found in App Store Connect. Attempting to create it automatically...")
        UI.important("")
        
        begin
          # Try to create the app automatically
          create_app
          UI.important("")
          UI.important("🔄 Retrying upload to TestFlight...")
          UI.important("")
          
          release_notes = generate_release_notes
          upload_to_testflight(**testflight_upload_options(ipa_path, changelog: release_notes))
          
          UI.success("✅ Successfully uploaded to App Store Connect!")
          UI.message("📱 Check App Store Connect for build processing status")
        rescue => create_ex
          UI.error("")
          UI.error("❌ Failed to create app or upload: #{create_ex.message}")
          UI.error("")
          UI.error("   📋 Manual Setup Steps:")
          UI.error("")
          UI.error("   1. Go to App Store Connect: https://appstoreconnect.apple.com")
          UI.error("   2. Sign in with your Apple ID: wayneyu.dev@gmail.com")
          UI.error("   3. Click 'My Apps' → Click the '+' button → 'New App'")
          UI.error("   4. Fill in the required information:")
          UI.error("      - Platform: iOS")
          UI.error("      - Name: Triftly (or your app name)")
          UI.error("      - Primary Language: (select your language)")
          UI.error("      - Bundle ID: com.triftly")
          UI.error("      - SKU: (any unique identifier, e.g., 'triftly-001')")
          UI.error("      - User Access: Full Access (or as needed)")
          UI.error("   5. Click 'Create'")
          UI.error("")
          UI.error("   ⚠️  Note: After creating the app, wait a few minutes for it to propagate")
          UI.error("      Then try uploading again.")
          UI.error("")
          UI.error("   💡 Or try creating the app using Fastlane:")
          UI.error("      bundle exec fastlane ios create_app")
          UI.error("")
          raise
        end
      else
        UI.error("❌ Failed to upload to TestFlight")
        UI.error("   Error: #{error_msg}")
        UI.error("")
        raise
      end
    end
  end

  desc "Create app in App Store Connect"
  desc "This will register your app in App Store Connect if it doesn't exist"
  lane :create_app do
    UI.message("📱 Creating app in App Store Connect...")
    UI.important("⚠️  This requires App Store Connect access")
    
    begin
      api_key = build_app_store_connect_api_key
      produce_options = {
        app_identifier: "com.triftly",
        app_name: "Triftly",
        team_id: "3G34999H3A",
        skip_itc: false,
        skip_devcenter: false
      }
      if api_key
        produce_options[:api_key] = api_key
      else
        produce_options[:username] = ENV["FASTLANE_USER"] || "wayneyu.dev@gmail.com"
      end
      produce(**produce_options)
      
      UI.success("✅ App created successfully in App Store Connect!")
      UI.message("📝 You can now upload to TestFlight using: bundle exec fastlane ios upload_testflight")
    rescue => ex
      error_msg = ex.message
      
      if error_msg.include?("already exists") || error_msg.include?("already registered")
        UI.important("ℹ️  App already exists in App Store Connect")
        UI.message("   You can proceed with uploading to TestFlight")
      else
        UI.error("❌ Failed to create app: #{error_msg}")
        UI.error("")
        UI.error("   📋 Manual Setup:")
        UI.error("      1. Go to https://appstoreconnect.apple.com")
        UI.error("      2. Sign in and create the app manually")
        UI.error("      3. Bundle ID: com.triftly")
        UI.error("")
        raise
      end
    end
  end

  desc "Revoke excess API-created certificates on CI (frees Apple cert slots)"
  lane :prune_excess_certificates_for_ci do
    return unless ENV["CI"]
    return unless connect_api_for_spaceship

    # Only prune Development certs. Distribution cert is reused via IOS_DISTRIBUTION_CERT_* secrets.
    revoked_ids = []

    %w[DEVELOPMENT IOS_DEVELOPMENT].each do |type|
      prune_certificates_of_type(type, keep: 0, revoked_ids: revoked_ids)
    end
  end

  desc "Setup App Store distribution certificates and provisioning profiles"
  desc "This will download/create Distribution certificate and App Store provisioning profile"
  lane :setup_appstore_signing do
    UI.message("🔧 Setting up App Store distribution signing...")
    
    # Use App Store Connect API key when available (CI), fallback to Apple ID (local)
    api_key_params = app_store_connect_api_key_params
    
    begin
      if ENV["CI"]
        unless api_key_params
          UI.user_error!(
            "APP_STORE_CONNECT_API_KEY_ID, APP_STORE_CONNECT_ISSUER_ID, and " \
            "APP_STORE_CONNECT_API_KEY_CONTENT must be set for CI signing."
          )
        end
        import_distribution_certificate_for_ci!
        unless distribution_identity_installed?
          UI.user_error!(
            "No Apple Distribution identity in keychain. Set GitHub secrets " \
            "IOS_DISTRIBUTION_CERT_BASE64 and IOS_DISTRIBUTION_CERT_PASSWORD " \
            "from a valid App Store Distribution .p12 (must match the cert on Apple Developer)."
          )
        end
        UI.message("📜 Reusing imported Apple Distribution certificate on CI")
      else
        UI.message("📜 Getting App Store Distribution certificate...")
        if api_key_params
          get_certificates(
            development: false,
            api_key: app_store_connect_api_key(**api_key_params),
            team_id: "3G34999H3A"
          )
        else
          get_certificates(
            development: false,
            username: ENV["FASTLANE_USER"] || "wayneyu.dev@gmail.com",
            team_id: "3G34999H3A"
          )
        end
      end
      
      domains_signing_ready = prepare_associated_domains_signing!(app_identifier: "com.triftly")

      # Get or create App Store provisioning profiles (app + share extension)
      UI.message("📋 Getting App Store provisioning profile for com.triftly...")
      main_profile = fetch_appstore_profile!(
        app_identifier: "com.triftly",
        force: ENV["CI"] && domains_signing_ready
      )
      if ENV["CI"] && domains_signing_ready
        UI.message("🔄 Regenerating App Store profile (Associated Domains entitlements)")
      end

      UI.message("📋 Getting App Store provisioning profile for #{TRIFTLY_SHARE_BUNDLE_ID}...")
      share_profile = fetch_appstore_profile!(
        app_identifier: TRIFTLY_SHARE_BUNDLE_ID,
        force: ENV["CI"]
      )

      ENV["SIGH_NAME"] = main_profile
      ENV["SIGH_NAME_TRIFTLY_SHARE"] = share_profile

      UI.success("✅ App Store distribution certificate and profiles are ready!")
      persist_ci_signing_env!
      UI.message("📝 You can now build for App Store using: bundle exec fastlane ios build_ipa export_method:app-store")
    rescue => ex
      UI.important("⚠️  Automatic certificate setup failed: #{ex.message}")
      UI.important("")
      UI.important("   Alternative: Set up manually in Xcode:")
      UI.important("   1. open ios/Runner.xcworkspace")
      UI.important("   2. Select Runner target → Signing & Capabilities")
      UI.important("   3. Enable 'Automatically manage signing'")
      UI.important("   4. Select your team (3G34999H3A)")
      UI.important("")
      raise
    end
  end

  desc "Increment build number"
  lane :increment_build do
    increment_build_number(
      xcodeproj: "#{IOS_DIR}/Runner.xcodeproj"
    )
    UI.success("✅ Build number incremented!")
  end

  desc "Clean iOS build artifacts"
  lane :clean do
    sh("cd #{PROJECT_ROOT} && flutter clean")
    sh("cd #{IOS_DIR} && rm -rf Pods Podfile.lock")
    begin
      sh("cd #{IOS_DIR} && env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u BUNDLE_PATH /opt/homebrew/bin/pod install", log: false)
    rescue => ex
      # Silently continue - user can run pod install manually if needed
    end
    UI.success("✅ Clean completed!")
  end
end

