APP_ENV=development
API_BASE_URL=
API_BASE_TOKEN=

# Google Maps (enable Maps + Geocoding APIs in Cloud Console)
GOOGLE_MAPS_API_KEY=

# Supabase — Project Settings → API (client-safe publishable key only)
# Never put sb_secret_ or service_role keys in this app.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
